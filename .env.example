# -----------------------------------------------------------------------------
# 🇮🇳 ELECTION GUIDE AI - ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------

# 🔐 GOOGLE GEMINI API CONFIGURATION
# Get your key from: https://aistudio.google.com/
GOOGLE_API_KEY=your_api_key_here_missing_this_will_trigger_fallback

# 🧠 MODEL SETTINGS
# Recommended: gemini-1.5-flash (Fast) or gemini-1.5-pro (Complex)
GEMINI_MODEL=gemini-1.5-flash

# ⚙️ APP SETTINGS
# Options: development, production
ENV=development

# 📝 LOGGING
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 🌐 SERVER CONFIG (For local Docker/Uvicorn runs)
PORT=8080
HOST=0.0.0.0
